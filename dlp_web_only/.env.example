# ============================================================================
# CYBER SENTINEL ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# IMPORTANT: This is a TEMPLATE file. Copy it to .env and fill in real values
# DO NOT commit .env to version control - only this .env.example file
#
# Production users: Replace all "your_*_here" values with actual credentials
# Keep .env file secure and never share or commit to git
# ============================================================================

# ============================================================================
# API Authentication
# ============================================================================
# Generate a secure API key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
DLP_API_KEY=your_secure_api_key_here

# ============================================================================
# Application Settings
# ============================================================================
# Flask environment: development, staging, or production
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_SECRET_KEY=your_flask_secret_key_here

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# ============================================================================
# Email/SMTP Configuration (for alert notifications)
# ============================================================================
# Alert email recipient
ALERT_EMAIL=security@company.com

# SMTP Server settings (if using email alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
SMTP_TLS_ENABLED=True

# ============================================================================
# Monitoring Configuration
# ============================================================================
# Paths to monitor (space-separated)
MONITORED_PATHS=./monitored_data

# Enable network scanning
NETWORK_SCAN_ENABLED=False

# Network scan targets (space-separated IPs, CIDRs, or hostnames)
NETWORK_SCAN_TARGETS=127.0.0.1

# Network scan ports (comma-separated)
NETWORK_SCAN_PORTS=21,22,23,80,135,139,443,445,3389

# Network scan interval in seconds
NETWORK_SCAN_INTERVAL=900

# ============================================================================
# Database Configuration (if applicable)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/cyber_sentinel
# DATABASE_USERNAME=your_db_username
# DATABASE_PASSWORD=your_db_password

# ============================================================================
# Third-party API Keys (Examples)
# ============================================================================
# Uncomment and fill in if using external services
# STRIPE_SECRET_KEY=sk_test_your_key_here
# OPENAI_API_KEY=sk-your_key_here
# AWS_ACCESS_KEY_ID=AKIA1234567890ABCDEF
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
# SLACK_BOT_TOKEN=xoxb-your-token-here
# SENDGRID_API_KEY=SG.your_key_here

# ============================================================================
# Security Settings
# ============================================================================
# Maximum upload size in MB
MAX_UPLOAD_SIZE=100

# Enable HTTPS/SSL
USE_HTTPS=False

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=cyber_sentinel.log

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_ADVANCED_SCANNING=True
FEATURE_NETWORK_SCANNING=False
FEATURE_EMAIL_ALERTS=False

# ============================================================================
# Security Best Practices
# ============================================================================
# Token expiration (in seconds)
TOKEN_EXPIRATION=3600

# Session timeout (in seconds)
SESSION_TIMEOUT=1800

# ============================================================================
# NOTES:
# ============================================================================
# 1. Never commit .env to version control
# 2. Use strong, unique values for all secrets
# 3. Rotate keys regularly (see SECURITY.md for procedures)
# 4. Use different keys for different environments (dev, staging, prod)
# 5. Store secrets in a secure vault in production (AWS Secrets Manager, etc.)
# 6. Always use HTTPS in production
# 7. Never share .env files via email or chat
# 8. Use environment-specific .env files: .env.local, .env.production, etc.
